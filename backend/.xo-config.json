{
  "rules": {
    "@typescript-eslint/naming-convention": [
      "error",
      {
        "selector": "variable",
        "modifiers": ["const", "global", "exported"],
        "format": ["UPPER_CASE", "strictCamelCase", "StrictPascalCase"]
      }
    ],
    "no-await-in-loop": "off",
    "import/extensions": "off",
    "n/file-extension-in-import": "off"
  }
}
