{
  "name": "backend",
  "version": "0.1.0",
  "description": "Dragons of Mugloar — backend service + bot.",
  "exports": "./main.js",
  "scripts": {
    "dev": "cross-env CONFIG_PATH=\".env.dev\" tsx watch src/main.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:unit": "vitest --run --exclude '**/*.integration.spec.ts'",
    "test:integration": "cross-env CONFIG_PATH=\".env.test\" vitest --run src/**/*.integration.spec.ts",
    "bot:run": "cross-env CONFIG_PATH=\".env.dev\" tsx src/bot/cli.ts",
    "lint": "xo"
  },
  "type": "module",
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/awilix": "^3.2.0",
    "awilix": "^8.0.1",
    "convict": "^6.2.4",
    "convict-format-with-validator": "^6.2.0",
    "dotenv": "^16.4.5",
    "fastify": "4.25.2",
    "fastify-plugin": "^4.5.1",
    "fastify-type-provider-zod": "^1.2.0",
    "pino": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "@tsconfig/strictest": "^2.0.5",
    "@types/convict": "^6.1.6",
    "@types/convict-format-with-validator": "^6.0.5",
    "@types/supertest": "^6.0.2",
    "cross-env": "^7.0.3",
    "supertest": "^7.0.0",
    "tsx": "^4.11.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "vitest-mock-extended": "^1.3.1",
    "xo": "^0.58.0"
  },
  "engines": {
    "node": ">=20"
  }
}